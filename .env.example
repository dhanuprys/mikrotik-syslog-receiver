# ===========================================
# Syslog Receiver Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# -------------------------------------------
# Syslog Server
# -------------------------------------------
# Address and port for the UDP syslog listener.
SYSLOG_LISTEN_ADDR=0.0.0.0:1514

# Syslog format: "auto", "rfc3164", or "rfc5424".
SYSLOG_FORMAT=auto

# -------------------------------------------
# DDoS Detection
# -------------------------------------------
# Prefix string used in MikroTik firewall log-prefix.
# Only messages containing this prefix trigger Telegram alerts.
DDOS_PREFIX=DDOS-ALERT:

# -------------------------------------------
# Telegram Bot
# -------------------------------------------
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Target chat or group ID for notifications.
TELEGRAM_CHAT_ID=your-chat-id-here

# Minimum seconds between Telegram messages (throttle).
TELEGRAM_THROTTLE_SEC=5

# -------------------------------------------
# Log File
# -------------------------------------------
# Path to the log file where all syslog events are stored.
LOG_FILE_PATH=./logs/syslog.log

# Max size of a single log file in megabytes before rotation.
LOG_MAX_SIZE_MB=100

# Max number of old rotated log files to keep.
LOG_MAX_BACKUPS=7

# Max number of days to retain old log files.
LOG_MAX_AGE_DAYS=30

# -------------------------------------------
# Worker
# -------------------------------------------
# Buffer size for the internal event channel.
WORKER_BUFFER_SIZE=1000
